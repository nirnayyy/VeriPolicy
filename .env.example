# Client-side (exposed to the browser — safe to publish).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Server-only (set these in Vercel/Netlify project settings — NEVER prefix
# with VITE_ or they will be bundled into the client).
GROQ_API_KEY=your_groq_api_key
NEWSDATA_API_KEY=your_newsdata_api_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_for_server_scripts_only
